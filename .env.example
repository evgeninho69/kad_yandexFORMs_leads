APP_ENV=production
LOG_LEVEL=info

# Bitrix24 on-prem
BITRIX_BASE_URL=https://bitrix.a2kad.ru
# Preferred: outbound webhook token from Bitrix admin (Приложения → Вебхуки).
# Format: https://bitrix.a2kad.ru/rest/<USER_ID>/<TOKEN>/
# If empty, falls back to BITRIX_SESSION_JSON (cookie-based).
BITRIX_WEBHOOK_TOKEN=

# Fallback: cookie-mode auth. Paste the JSON file from
# D:\11. 2KAD_Soft\8. 2KAD_bitrix\.bitrix-session.json (whole content) here.
# Used only if BITRIX_WEBHOOK_TOKEN is empty.
BITRIX_SESSION_JSON=

# Funnel (CATEGORY_ID) for 2KAD projects. ЮЛ/ФЛ unified since 2026-06-26.
BITRIX_FUNNEL_ID=3

# Bitrix user ID to assign as RESPONSIBLE_ID on new deals. 1 = info@2kad.ru (admin).
BITRIX_RESPONSIBLE_ID=1

# Notification: optional Telegram bot token + chat_id for owner pings.
# Leave empty to disable.
TG_BOT_TOKEN=
TG_OWNER_CHAT_ID=

# Optional: shared secret to verify Yandex webhook payloads.
# If set, we reject POSTs without header X-Webhook-Secret == value.
WEBHOOK_SHARED_SECRET=

# Server port (Dokploy sets PORT automatically; this is a fallback).
PORT=8000

# Yandex SMTP for auto-reply to customer (since 2026-07-07).
# Create app-password at https://id.yandex.ru/security/app-passwords → "Почта".
# Used by app/email_smtp.py to send instant acknowledgement after deal creation.
YANDEX_SMTP_HOST=smtp.yandex.ru
YANDEX_SMTP_PORT=587
YANDEX_SMTP_USER=info@2kad.ru
YANDEX_SMTP_PASSWORD=
YANDEX_SMTP_FROM_NAME=ООО Центр недвижимости 2КАД
